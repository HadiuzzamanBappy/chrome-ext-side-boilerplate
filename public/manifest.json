{
    "manifest_version": 3,
    "name": "Pagemind Pricing",
    "short_name": "Pagemind Pricing",
    "version": "1.0.0",
    "description": "Pagemind Pricing Page Analyzer",
    "author": "Hadiuzzaman Bappy",
    "homepage_url": "https://www.pagemind.io",
    "permissions": [
        "storage",
        "alarms",
        "notifications",
        "sidePanel",
        "activeTab"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "action": {
        "default_title": "Open Pagemind Pricing"
    },
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "assets/*",
                "icons/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "commands": {
        "_execute_side_panel": {
            "suggested_key": {
                "default": "Ctrl+Shift+P",
                "mac": "Command+Shift+P"
            },
            "description": "Open Pagemind Pricing Page Analyzer"
        }
    }
}